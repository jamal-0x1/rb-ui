# Public API base URL — must include /api suffix.
# Next.js requires the NEXT_PUBLIC_ prefix for vars exposed to the browser.
# Override locally via .env.local (gitignored). Override in prod via deploy env.
#
# Local dev:        http://localhost:3000/api
# Production:       https://rb-api.orbitalmind.xyz/api
NEXT_PUBLIC_API_URL=http://localhost:3000/api
